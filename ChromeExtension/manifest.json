{
  "manifest_version": 3,
  "name": "Kokoro TTS - Voice Selector",
  "version": "1.3",
  "permissions": [
    "contextMenus",
    "offscreen",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle_reader": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Start/Stop reading page"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pdf-viewer.html",
        "pdf-viewer.js",
        "lib/pdf.min.js",
        "lib/pdf.worker.min.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ]
}